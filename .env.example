APP_NAME="The Irons Backend"
APP_VERSION="0.1.0"
ENVIRONMENT=development
DEBUG=true

API_PREFIX=/api/v1

HOST=0.0.0.0
PORT=8000

CORS_ORIGINS=["http://localhost:3000"]

LOG_LEVEL=INFO

# RuneProfile (https://api.runeprofile.com/v1/docs)
RUNEPROFILE_BASE_URL=https://api.runeprofile.com/v1
# Optional API key for higher rate limits (request one in their Discord).
# RUNEPROFILE_API_KEY=
# Display name used by /api/v1/runeprofile/me.
# RUNEPROFILE_USERNAME=Zezima
# Sent on every upstream request; a Discord handle is recommended.
RUNEPROFILE_USER_AGENT="the-irons-backend (local-dev)"
RUNEPROFILE_TIMEOUT_SECONDS=10.0
